# Infinite Flight Live API key (free via the IF Connect program).
# Without it, the IFC connection returns a clear "not configured" error.
IF_API_KEY=

# ─────────────────────────────────────────────────────────────
# Suite control plane (managed from Aileron — see aileron/SUITE.md)
# ─────────────────────────────────────────────────────────────
# Contrail polls Aileron's /api/control to honor status / maintenance / flags.

# Aileron's URL. Only set if it's NOT the default https://aileronifc.vercel.app.
AILERON_CONTROL_URL=

# Must MATCH the CONTROL_SECRET set on Aileron. If Aileron has one and this is
# blank (or different), polls get 403 and Contrail fails-open to "operational".
CONTROL_SECRET=
